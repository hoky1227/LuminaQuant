    {
      "accessed_date": "2026-05-02",
      "core_idea": "Volatility-managed portfolios reduce risk when realized volatility is high; risk timing can improve Sharpe because expected returns do not rise one-for-one with volatility.",
      "failure_addressed": "Targets boost fragility and October-2025 circuit-breaker drawdown without simply increasing or lowering fixed exposure.",
      "repo_variant": "Added volatility_target_per_bar, min/max_volatility_exposure_multiplier to AdaptiveRegimeMomentumStrategy; vol_target_132 keeps boost signal but scales target allocation by target/realized_vol, clipped at 0.55..1.0.",
      "url": "https://www.nber.org/papers/w22208"
    },
    {
      "accessed_date": "2026-05-02",
      "core_idea": "Crypto time-series momentum can be strengthened with volume-weighted market returns.",
      "failure_addressed": "Investigated whether volume-aware breadth could fix breakout/reversion/liquidity failures; live-equivalent val rejected the attempted variants.",
      "repo_variant": "Implemented quote-volume history, volume-weighted broad regime, and volume-z entry gate; tested asym_dynamic and volume_guard modes.",
      "url": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4825389"
    },
    {
      "accessed_date": "2026-05-02",
      "core_idea": "Crypto intraday returns show both momentum and reversal; predictability changes around jumps and liquidity states.",
      "failure_addressed": "Explains why previous reversion/shock-fade candidates lost in validation; filters were attempted and rejected when validation stayed weak.",
      "repo_variant": "Kept live-equivalent minute decision cadence and avoided unconditional shock fade; tested volume/liquidity guarded variants rather than always-fade reversion.",
      "url": "https://www.sciencedirect.com/science/article/pii/S1062940822000833"
    },
    {
      "accessed_date": "2026-05-02",
      "core_idea": "Recent AdaptiveTrend paper combines high-frequency trend following with volatility-calibrated trailing stops and asymmetric long/short allocation.",
      "failure_addressed": "Documents why asymmetric/dynamic trailing was not promoted despite source support: it killed validation alpha.",
      "repo_variant": "Implemented dynamic trailing and long/short multipliers in AdaptiveRegimeMomentumStrategy; live-equivalent asym_dynamic/volume_guard rejected these settings, while volatility sizing survived.",
      "url": "https://arxiv.org/abs/2602.11708"
    },
    {
      "accessed_date": "2026-05-02",
      "core_idea": "Funding-rate history is available via Binance USD\u24c8-M futures REST data and can support carry/crowding research.",
      "failure_addressed": "Prevents claiming funding/open-interest alpha before the live-equivalent engine can consume those features consistently.",
      "repo_variant": "Not promoted in this patch because the live-equivalent strategy path currently validates OHLCV MARKET_WINDOW behavior; derivatives features remain next-family work.",
      "url": "https://developers.binance.com/docs/derivatives/usds-margined-futures/market-data/rest-api/Get-Funding-Rate-History"
    },
    {
      "accessed_date": "2026-05-02",
      "core_idea": "Open-interest statistics endpoint exposes futures crowding context but only latest-one-month history on that endpoint.",
      "failure_addressed": "Avoids mixing current-only derivatives endpoints into train/val without reproducible historical coverage.",
      "repo_variant": "Recorded as next-family data-engineering requirement, not as validated alpha.",
      "url": "https://developers.binance.com/docs/derivatives/usds-margined-futures/market-data/rest-api/Open-Interest-Statistics"
    }
  ]
